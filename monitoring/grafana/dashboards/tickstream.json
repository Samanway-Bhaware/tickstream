{
  "uid": "tickstream-overview",
  "title": "Tickstream Pipeline",
  "description": "End-to-end observability for the tickstream crypto data ingestion pipeline",
  "tags": ["tickstream", "crypto", "ingestion"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Messages Received / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(tickstream_msgs_received_total[1m])",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Ticks Parsed / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(tickstream_msgs_parsed_total[1m])",
          "legendFormat": "{{exchange}} / {{symbol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 50000, "color": "yellow" },
              { "value": 150000, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "tickstream_queue_depth",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Parse Errors / sec",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "rate(tickstream_parse_errors_total[1m])",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Reconnects / sec",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(tickstream_reconnects_total[1m])",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Ticks Written / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(tickstream_ticks_written_total[1m])",
          "legendFormat": "{{exchange}} / {{symbol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Write Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(tickstream_write_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(tickstream_write_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(tickstream_write_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Last Message Age",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 30, "color": "yellow" },
              { "value": 120, "color": "red" }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "tickstream_last_message_age_seconds",
          "legendFormat": "{{exchange}} / {{symbol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Cumulative Ticks Received",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(tickstream_msgs_received_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Cumulative Ticks Written",
      "type": "stat",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(tickstream_ticks_written_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Total Parse Errors",
      "type": "stat",
      "gridPos": { "x": 12, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(tickstream_parse_errors_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Total Reconnects",
      "type": "stat",
      "gridPos": { "x": 18, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(tickstream_reconnects_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
